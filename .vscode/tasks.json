{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "C:\\Program Files\\w64devkit\\bin\\gcc.exe",
            "args": [
                "-Wall",
                "-std=c23",
                "-fdiagnostics-color=always",
                "-g",
                "-I",
                "${workspaceFolder}\\include",
                "${workspaceFolder}\\src\\*.c",
                "${workspaceFolder}\\lib\\libglfw3.a",
                "-lopengl32",
                "-lgdi32",
                "-luser32",
                "-lkernel32",
                "-o",
                "${workspaceFolder}\\build\\app.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}